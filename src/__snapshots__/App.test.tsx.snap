// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`kubeconfig > renders the kubeconfig block when KUBEADM_ENABLED=TRUE 1`] = `
"<div data-slot="card" class="text-card-foreground flex flex-col gap-6 rounded-xl border py-6 bg-slate-800 border-slate-700 shadow-xl"><div data-slot="card-header" class="@container/card-header auto-rows-min grid-rows-[auto_auto] gap-1.5 px-6 has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6 flex flex-row items-center justify-between space-y-0"><div><div data-slot="card-title" class="font-semibold text-sm uppercase tracking-widest text-[#F4C624] flex items-center gap-2" style="font-family:'Cuprum', sans-serif;font-weight:600"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-terminal" aria-hidden="true"><path d="M12 19h8"></path><path d="m4 17 6-6-6-6"></path></svg> Kubeconfig</div></div><button type="button" style="font-family:'Cuprum', sans-serif;font-weight:600" class="flex items-center gap-2 py-2 px-4 rounded-lg bg-transparent border border-[#F4C624] text-[#F4C624] hover:bg-[#F4C624] hover:text-[#084218] transition-all shrink-0 ml-4"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-copy" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg> Copy</button></div><div data-slot="card-content" class="px-6"><pre class="overflow-x-auto rounded-md border border-slate-700 bg-slate-900/50 p-4 text-sm text-slate-300 font-mono"><code>apiVersion: v1
kind: Config
clusters:
  - name: nonprod.jupiter.onglueops.rocks
    cluster:
      server: https://kube-api.nonprod.jupiter.onglueops.rocks
      certificate-authority-data: ""
contexts:
  - name: nonprod.jupiter.onglueops.rocks
    context:
      cluster: nonprod.jupiter.onglueops.rocks
      user: nonprod.jupiter.onglueops.rocks
      namespace: nonprod
current-context: nonprod.jupiter.onglueops.rocks
users:
  - name: nonprod.jupiter.onglueops.rocks
    user:
      exec:
        apiVersion: client.authentication.k8s.io/v1
        env:
          - name: NODE_OPTIONS
            value: --no-deprecation
        command: kubectl
        args:
          - oidc-login
          - get-token
          - --grant-type=device-code
          - --oidc-issuer-url=https://dex.nonprod.jupiter.onglueops.rocks
          - --oidc-client-id=kubectl
          - --oidc-extra-scope=profile
          - --oidc-extra-scope=email
          - --oidc-extra-scope=groups
        interactiveMode: IfAvailable
</code></pre></div></div>"
`;

